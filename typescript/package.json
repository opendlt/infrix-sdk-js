{
  "name": "@infrix/client",
  "version": "0.1.0",
  "description": "TypeScript client for the Infrix governance-first execution platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
