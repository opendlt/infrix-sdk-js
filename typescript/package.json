{
  "name": "@infrix/client",
  "version": "0.1.0",
  "description": "TypeScript client for the Infrix governance-first execution platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "create-infrix-app": "dist/templates/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test \"dist/surface.test.js\" \"dist/sugar.test.js\" \"dist/results.test.js\" \"dist/golden/escrow.test.js\" \"dist/proofs/verifyLocal.test.js\" \"dist/flows.test.js\" \"dist/templates/templates.test.js\" \"dist/metamask/recoverPublicKey.test.js\" \"dist/metamask/withMetaMask.test.js\" \"dist/proofReceipt.test.js\" \"dist/userError.test.js\" \"dist/telemetry.test.js\" \"dist/agent/agent.test.js\" \"dist/scenario/scenario.test.js\" \"dist/ux/ux.test.js\" \"dist/tasks/tasks.test.js\" \"dist/remediation/remediation.test.js\" \"dist/inbox/inbox.test.js\" \"dist/identity/identity.test.js\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "infrix",
    "governance",
    "intent",
    "policy",
    "accumulate",
    "wasm",
    "blockchain"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opendlt/infrix-accumen.git",
    "directory": "sdk/typescript"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@noble/curves": "1.9.4",
    "@noble/hashes": "1.8.0"
  }
}
