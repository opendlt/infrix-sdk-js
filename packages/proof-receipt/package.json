{
  "name": "@infrix/proof-receipt",
  "version": "0.1.0",
  "description": "Verify an Infrix portable proof and render its receipt — in the browser or Node, with no node trust.",
  "type": "module",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "vendor/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/vendor.mjs",
    "pretest": "node scripts/vendor.mjs",
    "test": "node --test \"test/*.test.mjs\"",
    "prepack": "node scripts/vendor.mjs"
  },
  "keywords": [
    "infrix",
    "accumulate",
    "proof",
    "verification",
    "receipt"
  ],
  "devDependencies": {
    "@infrix/verify": "^0.1.0"
  },
  "sideEffects": false
}
